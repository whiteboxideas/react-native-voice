{
  "name": "react-native-voice-tools",
  "version": "0.1.0",
  "description": "A modular voice command library for React Native apps — STT, LLM tool-calling, TTS pipeline with pluggable providers.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./ui": {
      "types": "./dist/ui.d.ts",
      "default": "./dist/ui.js"
    },
    "./providers/openai": {
      "types": "./dist/providers-openai.d.ts",
      "default": "./dist/providers-openai.js"
    },
    "./providers/anthropic": {
      "types": "./dist/providers-anthropic.d.ts",
      "default": "./dist/providers-anthropic.js"
    },
    "./providers/expo-speech": {
      "types": "./dist/providers-expo-speech.d.ts",
      "default": "./dist/providers-expo-speech.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "react-native",
    "voice",
    "speech-to-text",
    "llm",
    "tts",
    "voice-commands",
    "whisper",
    "openai",
    "anthropic"
  ],
  "license": "MIT",
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.72.0",
    "expo-av": ">=14.0.0"
  },
  "peerDependenciesMeta": {
    "expo-haptics": { "optional": true },
    "expo-speech": { "optional": true },
    "expo-secure-store": { "optional": true },
    "expo-constants": { "optional": true },
    "expo-file-system": { "optional": true },
    "react-native-reanimated": { "optional": true }
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-reanimated": "~4.1.1",
    "expo-av": "~16.0.8",
    "expo-haptics": "~15.0.8",
    "expo-speech": "~14.0.8",
    "expo-secure-store": "~15.0.8",
    "expo-constants": "~18.0.13",
    "expo-file-system": "~19.0.21",
    "typescript": "~5.9.2"
  },
  "packageManager": "yarn@1.22.22+sha1.ac34549e6aa8e7ead463a7407e1c7390f61a6610"
}
